<% nav = SpeckitOrchestrator.Web.Layouts.nav_items() %>
<% escalations = SpeckitOrchestrator.Web.Layouts.escalations_count() %>
<% ctx = SpeckitOrchestrator.Web.Layouts.context() %>
<% run = SpeckitOrchestrator.Web.Layouts.run_view() %>
<div class="app-frame">
  <aside class="console-sidebar">
    <div class="console-logo">
      <div class="console-logo-mark"><div class="console-logo-mark-inner"></div></div>
      <div>
        <div class="console-brand-name">speckit_orchestrator</div>
        <div class="console-brand-sub">CONTROL PLANE · v1</div>
      </div>
    </div>

    <nav class="console-nav" aria-label="Console navigation">
      <a
        :for={{path, label} <- nav}
        href={path}
        class={["nav-item", assigns[:current_path] == path && "nav-active"]}
      >
        <span class="nav-glyph">{SpeckitOrchestrator.Web.Layouts.nav_glyph(label)}</span>
        <span class="nav-label">{label}</span>
        <.badge
          :if={label == "Escalations" and escalations > 0}
          text={to_string(escalations)}
          variant={:warn}
        />
      </a>
    </nav>

    <div class="console-footer">
      <div class="console-footer-label">TARGET REPO</div>
      <div class="console-footer-value">{ctx.repo}</div>
      <div class="console-status-row">
        <span class="status-dot" data-ok={ctx.cli_auth == "available"}></span>
        <span>claude CLI · {ctx.cli_auth}</span>
      </div>
      <div class="console-status-row">
        <span class="status-dot" data-ok={ctx.runtime == "up"}></span>
        <span>BEAM · {ctx.runtime}</span>
      </div>
    </div>
  </aside>

  <div class="content-column console-main">
    <header class="console-topbar" data-active={run.active?}>
      <div class="topbar-run">
        <%= if run.active? do %>
          <span class="run-state-chip run-state-active">● live</span>
          <div class="run-info">
            <div class="run-title">{run.title}</div>
            <div class="run-meta">{run.mode} · cap {SpeckitOrchestrator.Config.max_concurrency()}</div>
          </div>
        <% else %>
          <span class="run-state-chip run-state-idle">idle</span>
          <div class="run-info">
            <div class="run-title run-title-empty">{run.title}</div>
          </div>
        <% end %>
      </div>

      <div class="topbar-divider"></div>

      <%= if run.active? do %>
        <div class="topbar-gauge">
          <.cost_gauge
            committed={run.committed}
            reserved={run.reserved}
            budget={run.budget}
            tripped?={run.tripped?}
          />
        </div>
        <span class={"breaker-chip breaker-#{if run.tripped?, do: "tripped", else: "armed"}"}>
          {if run.tripped?, do: "breaker tripped", else: "breaker armed"}
        </span>
      <% end %>

      <div class="topbar-clock">
        <span id="console-clock">{run.clock}</span>
      </div>
    </header>

    <div class="console-content">
      {@inner_content}
    </div>

    <div class="console-toasts" id="console-toasts">
      <.toast
        :for={{kind, message} <- @flash}
        id={"flash-#{kind}"}
        kind={String.to_existing_atom(kind)}
        message={message}
      />
      <.toast :for={t <- assigns[:toasts] || []} id={t.id} kind={t.kind} message={t.message} />
    </div>

    <!-- Drawer slot: filled by FeatureDrawerComponent in a later phase. -->
    <div class="console-drawer-slot" id="console-drawer-slot"></div>
  </div>
</div>
